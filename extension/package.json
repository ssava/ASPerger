{
    "name": "asperger-debug",
    "displayName": "ASPerger Debugger",
    "description": "Debug adapter for ASP Classic / VBScript files",
    "version": "0.1.0",
    "engines": {
        "vscode": "^1.60.0"
    },
    "categories": [
        "Debuggers",
        "Programming Languages"
    ],
    "activationEvents": [
        "onDebug",
        "onLanguage:asp"
    ],
    "main": "./extension.js",
    "contributes": {
        "languages": [
            {
                "id": "asp",
                "configuration": "./language-configuration.json",
                "aliases": ["ASP", "ASP Classic", "asp"],
                "extensions": [".asp", ".asa"]
            }
        ],
        "grammars": [
            {
                "language": "asp",
                "scopeName": "text.html.asp",
                "path": "./syntaxes/asp.html.tmLanguage.json",
                "embeddedLanguages": {
                    "text.html.asp": "asp",
                    "text.html": "html",
                    "source.asp": "vbscript"
                }
            }
        ],
        "breakpoints": [
            { "language": "asp" }
        ],
        "snippets": [
            {
                "language": "asp",
                "path": "./snippets/asp.code-snippets"
            }
        ],
        "debuggers": [
            {
                "type": "asperger",
                "label": "ASPerger Debugger",
                "program": "./bin/asperger-debug",
                "languages": ["asp"],
                "configurationAttributes": {
                    "launch": {
                        "required": [],
                        "properties": {
                            "folder": {
                                "type": "string",
                                "description": "Root directory to serve ASP files from"
                            },
                            "program": {
                                "type": "string",
                                "description": "Path to an .asp file; its parent directory is used as served root if 'folder' is not set"
                            },
                            "port": {
                                "type": "number",
                                "default": 9090,
                                "description": "HTTP server port for the debug session"
                            },
                            "defaultDocument": {
                                "type": "string",
                                "default": "",
                                "description": "(Deprecated) Use defaultDocuments instead. Single default file served when requesting a directory."
                            },
                            "defaultDocuments": {
                                "type": "array",
                                "items": { "type": "string" },
                                "default": ["default.asp", "default.htm", "default.html", "index.asp", "index.htm", "index.html", "iisstart.htm"],
                                "description": "Prioritized list of default files to try when requesting a directory (IIS-like fallback chain)"
                            },
                            "directoryListing": {
                                "type": "boolean",
                                "default": false,
                                "description": "Enable directory listing when no default document is found"
                            }
                        }
                    }
                },
                "initialConfigurations": [
                    {
                        "type": "asperger",
                        "request": "launch",
                        "name": "Debug ASP file",
                        "folder": "${workspaceFolder}/asp_files"
                    }
                ]
            }
        ]
    }
}
